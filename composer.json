{
  "name": "irivengroup/world-datasets",
  "description": "Enterprise-ready PHP world datasets library with harmonized public API, SQLite/JSON/CSV sources, fluent collections, value objects, validation and export tools.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Iriven\\WorldDatasets\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Iriven\\WorldDatasets\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.2",
    "ext-pdo": "*",
    "ext-sqlite3": "*",
    "psr/log": "^3.0",
    "psr/simple-cache": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.12"
  },
  "suggest": {
    "monolog/monolog": "For production logging integration"
  },
  "scripts": {
    "import-data": "php bin/import_countries.php",
    "validate-data": "php bin/validate_countries.php",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "countries": "php bin/countries",
    "build-data": "php bin/build_data.php",
    "check-data": "php bin/check_data.php",
    "doctor": "php bin/countries-doctor"
  },
  "keywords": [
    "php",
    "world",
    "datasets",
    "countries",
    "iso3166",
    "sqlite",
    "json",
    "csv",
    "symfony",
    "laravel"
  ],
  "homepage": "https://github.com/irivengroup/world-datasets",
  "support": {
    "issues": "https://github.com/irivengroup/world-datasets/issues",
    "source": "https://github.com/irivengroup/world-datasets"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "version": "1.0.0"
}